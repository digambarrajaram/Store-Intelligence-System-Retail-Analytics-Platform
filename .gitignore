# .gitignore for CV Pipeline

# Dependencies
node_modules/
__pycache__/
*.py[cod]
*$py.class
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
.model_cache/

# Build output
dashboard/dist/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Docker
docker-compose.override.yml
.docker/

# Video files (large, not for commit)
videos/
*.mp4
*.avi
*.mov
*.mkv
*.webm

# Model files (if stored locally, but we use a volume)
models/
*.pt
*.onnx
*.pth
*.weights

# Output directories (if used locally, but we use volumes)
output/
detection_output/

# Python packaging
*.egg-info/
*.egg
*.whl
.pip/
pip-log.txt
pip-delete-this-directory.txt

# Miscellaneous
*.exe
*.tmp
*.temp
.cache/
tmp/
temp/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.noxtestresults/
.node_replay_history
.mypy_cache/
.ruff_cache/

# Package files (if you ever package the project)
*.tar
*.tar.gz
*.zip

# Environment variables (keep the template if you have one, but ignore actual values)
# .env.example  # uncomment this line if you want to keep an example

# Kafka data (if stored locally, but we use a volume)
kafka_data/
zookeeper_data/
zookeeper_log/
redis_data/

# Grafana provisioning is bind-mounted into containers, so local config is not tracked here

# Prometheus data (if stored locally, but we use a volume)
prometheus_data/

# End of file
