# ──────────────────────────────────────────────────────────────────────────────
# Vercel Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Set these in the Vercel Dashboard (Settings → Environment Variables)
# for your project.
#
# Required:
#   VERCEL=1 (automatically set by Vercel)
#
# Redis (optional — for connecting to Upstash Redis or similar):
#   REDIS_HOST=your-redis-host.upstash.io
#   REDIS_PORT=6379
#   REDIS_PASSWORD=your-redis-password
#   REDIS_URL=redis://default:password@your-redis-host.upstash.io:6379
#
# Alternative Redis env vars (also checked):
#   UPSTASH_REDIS_HOST=your-redis-host.upstash.io
#   UPSTASH_REDIS_PORT=6379
#   UPSTASH_REDIS_PASSWORD=your-redis-password
#
# Dashboard (set during build):
#   VITE_API_URL=/api/v1
#   VITE_WS_URL=wss://your-project.vercel.app/ws/alerts
#   VITE_ACTIVE_CAMERAS=4
#   VITE_BUILD_VERSION=2.0.0
#   VITE_ENVIRONMENT=Production
#
# Python:
#   PYTHONUNBUFFERED=1
